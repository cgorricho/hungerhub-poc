# Oracle Database Configuration
ORACLE_HOST=your_oracle_server_ip
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=your_service_name
ORACLE_USERNAME=your_username
ORACLE_PASSWORD=your_password

# Optional: TNS connection string
ORACLE_DSN=your_dsn_string

# Application Configuration
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8050

# Data Processing
CHUNK_SIZE=10000
MAX_RECORDS=1000000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/hungerhub_poc.log
