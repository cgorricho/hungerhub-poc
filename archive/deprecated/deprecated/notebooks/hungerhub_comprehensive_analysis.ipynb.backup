    "            print(f\"{'='*60}\")\n",
    "            \n",
    "            # Numeric analysis\n",
    "            numeric_summary = eda.analyze_numeric_columns(df, dataset_name)\n",
    "            \n",
    "            # Categorical analysis \n",
    "            categorical_summary = eda.analyze_categorical_columns(df, dataset_name)\n",
    "            \n",
    "            # Store results\n",
    "            univariate_results[dataset_name] = {\n",
