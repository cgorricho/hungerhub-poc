    "                    if df[col].count() > 0:\n",
    "                        date_range = df[col].dropna()\n",
    "                        print(f\"   {col}: {date_range.min()} to {date_range.max()} ({len(date_range)} records)\")\n",
    "                        \n",
    "                        # Check for date patterns\n",
    "                        date_span_days = (date_range.max() - date_range.min()).days\n",
