   "source": [
    "# Bivariate Relationship Analysis\n",
    "if 'advanced_analysis' in globals():\n",
    "    print(\"BIVARIATE RELATIONSHIP ANALYSIS\")\n",
    "    print(\"=\" * 50)\n",
    "    \n",
    "    # Analyze numeric relationships\n",
    "    print(\"\\n1. NUMERIC VARIABLE RELATIONSHIPS:\")\n",
