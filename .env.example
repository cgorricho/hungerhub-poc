# Database Configuration
CHOICE_DB_SERVER=choice-sql-server.database.windows.net
CHOICE_DB_NAME=Choice
AGENCY_DB_SERVER=agencyexpress-sql-server.database.windows.net  
AGENCY_DB_NAME=AgencyExpress

# Authentication
DB_AUTH_METHOD=ActiveDirectoryDefault

# Application Settings
DEBUG=true
LOG_LEVEL=INFO
ETL_BATCH_SIZE=1000
DATA_RETENTION_DAYS=90

# API Configuration (for future development)
API_SECRET_KEY=your-secret-key-here
API_HOST=localhost
API_PORT=8000

# Dashboard Configuration (for future development)  
DASHBOARD_HOST=localhost
DASHBOARD_PORT=8501
DASHBOARD_TITLE="HungerHub Analytics Dashboard"

# File Paths
DATA_PATH=./data
LOGS_PATH=./logs
OUTPUT_PATH=./data/output

# Performance Settings
ENABLE_CACHING=true
CACHE_TTL_MINUTES=30
MAX_WORKERS=4
