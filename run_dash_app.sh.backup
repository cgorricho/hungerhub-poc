#!/bin/bash

# HungerHub POC - Dash Dashboard Launcher
# This script runs from /home/tagazureuser and launches the Dash app

PROJECT_DIR="/home/tagazureuser/cgorr/2week_poc_execution/hungerhub_poc"
VENV_PATH="$PROJECT_DIR/venv"
DASH_APP_PATH="$PROJECT_DIR/src/dashboard/dash"
LOG_DIR="$PROJECT_DIR/logs"

# Create logs directory if it doesn't exist
mkdir -p "$LOG_DIR"

# Timestamp for log files
TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
LOG_FILE="$LOG_DIR/dash_app_$TIMESTAMP.log"

echo "Starting Dash Dashboard..." | tee -a "$LOG_FILE"
echo "Log file: $LOG_FILE" | tee -a "$LOG_FILE"

# Check if virtual environment exists
if [ ! -d "$VENV_PATH" ]; then
    echo "Error: Virtual environment not found at $VENV_PATH" | tee -a "$LOG_FILE"
    exit 1
fi

# Activate virtual environment and run Dash app from project root
cd "$PROJECT_DIR"
source "$VENV_PATH/bin/activate"

echo "Activated virtual environment" | tee -a "$LOG_FILE"
echo "Running from project root: $PROJECT_DIR" | tee -a "$LOG_FILE"
echo "Dash app path: $DASH_APP_PATH" | tee -a "$LOG_FILE"

# Run the Dash app with logging (from project root)
python src/dashboard/dash/app.py 2>&1 | tee -a "$LOG_FILE"

deactivate
echo "Dash app stopped" | tee -a "$LOG_FILE"
